pipeline {

 agent any

 stages {

   stage('Clone') {
     steps {
       git 'https://github.com/priyankashinde-patil/springboot-devops.git'
     }
   }

   stage('Build') {
     steps {
       sh 'mvn clean package'
     }
   }

   stage('Docker Build') {
     steps {
       sh 'docker build -t priyushinde/app .'
     }
   }

   stage('Docker Push') {
     steps {
       sh 'docker push priyushinde/app'
     }
   }

   stage('Deploy') {
     steps {
       sh 'kubectl apply -f deployment.yml'
       sh 'kubectl apply -f service.yml'
     }
   }
 }
}